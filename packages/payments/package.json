{
  "name": "@agelormini2024/payments",
  "version": "0.1.0",
  "description": "Módulo de pagos reutilizable para NestJS (Stripe + MercadoPago)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "mercadopago": "^2.0.0",
    "reflect-metadata": "^0.1.13",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "mercadopago": "^2.12.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "stripe": "^17.7.0",
    "ts-jest": "^29.4.9"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
